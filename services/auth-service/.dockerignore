pnpm-debug.log

# Build outputs (will build in container)
dist
build
*.tsbuildinfo

# Git
.git
.gitignore

# Environment files (use docker-compose environment instead)
.env
.env.local
.env.*.local

# IDE
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Tests and docs
*.md
tests/
coverage/

# Docker itself
Dockerfile
.dockerignore
docker-compose.yml

